{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hestia",
  "version": "0.0.1",
  "identifier": "tech.lawrenceallen.hestia",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../../frontend && bun run dev",
    "beforeBuildCommand": "cd ../../frontend && bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hestia",
        "width": 1100,
        "height": 720,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
