{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hestia",
  "version": "0.0.1",
  "identifier": "tech.lawrenceallen.hestia",
  "build": {
    "beforeDevCommand": "cd ../frontend && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../frontend && bun run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hestia",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Fast, lightweight Minecraft launcher",
    "longDescription": "Hestia is a cross-platform Minecraft launcher. The desktop app is a thin client that drives the bundled hestiad daemon over a local socket.",
    "publisher": "toraaoo",
    "homepage": "https://github.com/toraaoo/hestia",
    "copyright": "Copyright © 2026 toraaoo",
    "externalBin": [
      "binaries/hestiad",
      "binaries/tray",
      "binaries/hestia"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi",
        "installMode": "both",
        "startMenuFolder": "Hestia"
      }
    }
  }
}
