#!/bin/sh
#
# Enforce the Conventional-Commit subject format
# `<type>(<scope>): <description>` (scope optional, `!` marks a breaking change).
# Managed by husky-rs. Skip with `git commit --no-verify`.
set -e

msg_file=$1

# First line that is neither a comment nor blank.
subject=$(grep -vE '^[[:space:]]*#' "$msg_file" | grep -vE '^[[:space:]]*$' | head -n1)

# Git-generated merge/revert/fixup subjects are exempt.
case "$subject" in
    "Merge "* | "Revert "* | "fixup!"* | "squash!"*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'
if ! printf '%s' "$subject" | grep -qE "$pattern"; then
    echo "husky: commit message does not match <type>(<scope>): <description>" >&2
    echo "  got:  $subject" >&2
    echo "  type: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert" >&2
    echo "  e.g.: feat(daemon): add process supervisor" >&2
    exit 1
fi
