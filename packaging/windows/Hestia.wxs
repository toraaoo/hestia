<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v4 package for Hestia.
  Build via CI/local - do NOT edit UpgradeCode; it must stay stable across releases.

  Required defines (pass with -d):
    Version    - X.Y.Z  (e.g. 1.0.0)
    StagingDir - absolute path to artifacts/stage/win-x64
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Hestia"
           Manufacturer="Hestia"
           Version="$(var.Version)"
           UpgradeCode="{2B9F3C1E-4A7D-4E8B-9C2A-1B3D5E7F9A0B}"
           Scope="perUserOrMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Hestia is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      WixUI_Advanced shows a per-user / per-machine scope selection dialog.
      WixPerUserFolder is the default (unchecked = per-user, per the plan).
      When per-machine is selected the UI sets ALLUSERS=1.
    -->
    <Property Id="ApplicationFolderName" Value="Hestia" />
    <Property Id="WixAppFolder" Value="WixPerUserFolder" />
    <ui:WixUI Id="WixUI_Advanced" />

    <!-- Make PATH changes visible in newly-launched shells. -->
    <util:BroadcastEnvironmentChange />

    <!-- Directory tree; APPLICATIONFOLDER is reparented at runtime by WixUI_Advanced -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="UserProgramsFolder" Name="Programs">
        <Directory Id="APPLICATIONFOLDER" Name="Hestia" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="UserHestiaMenuFolder" Name="Hestia" />
    </StandardDirectory>

    <StandardDirectory Id="CommonProgramMenuFolder">
      <Directory Id="MachineHestiaMenuFolder" Name="Hestia" />
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="Hestia" Level="1">
      <ComponentGroupRef Id="AppBinaries" />
      <ComponentRef Id="GuiShortcutUser" />
      <ComponentRef Id="GuiShortcutMachine" />
      <ComponentRef Id="UserPathEnv" />
      <ComponentRef Id="MachinePathEnv" />
    </Feature>

    <!-- Application binaries -->
    <ComponentGroup Id="AppBinaries" Directory="APPLICATIONFOLDER">
      <!-- Auto-harvest everything from the staging folder. -->
      <Files Include="$(var.StagingDir)\**" />
    </ComponentGroup>

    <!-- Start Menu shortcut for the GUI only (no TUI shortcut per plan) -->
    <Component Id="GuiShortcutUser" Directory="UserHestiaMenuFolder" Condition="NOT ALLUSERS">
      <Shortcut Id="StartMenuShortcut"
                Name="Hestia"
                Target="[APPLICATIONFOLDER]Hestia.Desktop.exe"
                WorkingDirectory="APPLICATIONFOLDER" />
      <RemoveFolder Id="RemoveUserHestiaMenuFolder" Directory="UserHestiaMenuFolder" On="uninstall" />
      <!-- Registry key required as KeyPath for shortcut components -->
      <RegistryValue Root="HKCU"
                     Key="Software\Hestia"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="GuiShortcutMachine" Directory="MachineHestiaMenuFolder" Condition="ALLUSERS">
      <Shortcut Id="StartMenuShortcutMachine"
                Name="Hestia"
                Target="[APPLICATIONFOLDER]Hestia.Desktop.exe"
                WorkingDirectory="APPLICATIONFOLDER" />
      <RemoveFolder Id="RemoveMachineHestiaMenuFolder" Directory="MachineHestiaMenuFolder" On="uninstall" />
      <!-- Registry key required as KeyPath for shortcut components -->
      <RegistryValue Root="HKLM"
                     Key="Software\Hestia"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!--
      PATH components: exactly one installs based on scope.
      ALLUSERS="" → per-user install → modify user PATH.
      ALLUSERS=1  → per-machine install → modify system PATH.
    -->
    <Component Id="UserPathEnv" Directory="APPLICATIONFOLDER" Condition="NOT ALLUSERS">
      <Environment Id="UserPATH"
                   Name="PATH"
                   Value="[APPLICATIONFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="no" />
      <RegistryValue Root="HKCU"
                     Key="Software\Hestia"
                     Name="UserPath"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="MachinePathEnv" Directory="APPLICATIONFOLDER" Condition="ALLUSERS">
      <Environment Id="MachinePATH"
                   Name="PATH"
                   Value="[APPLICATIONFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <RegistryValue Root="HKLM"
                     Key="Software\Hestia"
                     Name="MachinePath"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Package>
</Wix>
