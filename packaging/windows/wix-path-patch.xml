<?xml version="1.0" encoding="utf-8"?>
<!-- Adds the install bin/ dir to the system PATH so the `hestia` CLI is usable
     from any shell after an MSI install (NSIS does this via MODIFY_PATH). -->
<CPackWiXPatch>
  <CPackWiXFragment Id="#PRODUCTFEATURE">
    <ComponentRef Id="CM_HESTIA_PATH"/>
  </CPackWiXFragment>
  <CPackWiXFragment Id="#PRODUCT">
    <DirectoryRef Id="INSTALL_ROOT">
      <Component Id="CM_HESTIA_PATH" Guid="*">
        <Environment Id="HestiaPath" Name="PATH" Value="[INSTALL_ROOT]bin"
                     Part="last" Action="set" System="yes" Permanent="no"/>
        <RegistryValue Root="HKLM" Key="Software\Hestia" Name="PathRegistered"
                       Type="integer" Value="1" KeyPath="yes"/>
      </Component>
    </DirectoryRef>
  </CPackWiXFragment>
</CPackWiXPatch>
